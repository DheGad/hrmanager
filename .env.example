# =============================================================================
# HRManager4U.ai — Environment Variables Template
# Copy this file to .env and fill in the values
# NEVER commit .env to version control
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=development
APP_NAME=HRManager4U
APP_VERSION=1.0.0
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# -----------------------------------------------------------------------------
# API Server
# -----------------------------------------------------------------------------
API_PORT=4000
API_HOST=0.0.0.0

# -----------------------------------------------------------------------------
# JWT Configuration
# Generate RS256 key pair:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
#   base64 -i private.pem | tr -d '\n' > private.b64
#   base64 -i public.pem | tr -d '\n' > public.b64
# -----------------------------------------------------------------------------
JWT_PRIVATE_KEY=<base64-encoded-rs256-private-key>
JWT_PUBLIC_KEY=<base64-encoded-rs256-public-key>
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# Database (PostgreSQL + pgvector)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://hrmanager:hrmanager_secret@localhost:5432/hrmanager4u?schema=public
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=hrmanager4u
DATABASE_USER=hrmanager
DATABASE_PASSWORD=hrmanager_secret

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret
REDIS_DB=0
REDIS_TTL=300

# -----------------------------------------------------------------------------
# Storage (S3-compatible — MinIO for dev, Cloudflare R2 for production)
# -----------------------------------------------------------------------------
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_PORT=9000
STORAGE_USE_SSL=false
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin_secret
STORAGE_BUCKET_NAME=hrmanager4u
STORAGE_REGION=ap-southeast-1
STORAGE_CDN_URL=http://localhost:9000/hrmanager4u

# For Cloudflare R2 (production), set:
# STORAGE_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# STORAGE_USE_SSL=true

# -----------------------------------------------------------------------------
# LLM Provider (OpenAI)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.1

# -----------------------------------------------------------------------------
# Email (SMTP)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@hrmanager4u.ai
SMTP_PASS=your-smtp-password
SMTP_FROM_NAME=HRManager4U
SMTP_FROM_EMAIL=noreply@hrmanager4u.ai

# For SendGrid:
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=SG.your-sendgrid-api-key

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
THROTTLE_AI_LIMIT=20

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,https://hrmanager4u.ai
CORS_CREDENTIALS=true

# -----------------------------------------------------------------------------
# Encryption (for PII fields at rest)
# Generate: openssl rand -hex 32
# -----------------------------------------------------------------------------
ENCRYPTION_KEY=your-32-byte-hex-encryption-key
ENCRYPTION_IV_LENGTH=16

# -----------------------------------------------------------------------------
# Super Admin (seeded on first startup)
# -----------------------------------------------------------------------------
SUPER_ADMIN_EMAIL=superadmin@hrmanager4u.ai
SUPER_ADMIN_PASSWORD=Change_Me_Immediately_2024!

# -----------------------------------------------------------------------------
# Puppeteer (PDF generation)
# -----------------------------------------------------------------------------
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
PUPPETEER_NO_SANDBOX=true

# -----------------------------------------------------------------------------
# MinIO (dev only — for docker-compose)
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_secret
MINIO_CONSOLE_PORT=9001

# -----------------------------------------------------------------------------
# Monitoring (optional)
# -----------------------------------------------------------------------------
SENTRY_DSN=
PROMETHEUS_ENABLED=false
PROMETHEUS_PORT=9090
