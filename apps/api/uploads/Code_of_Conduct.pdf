<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Strict//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-strict.dtd">
<html xmlns="http://www.w3.org/1999/xhtml" xml:lang="en-ca">
  <head>
    <meta
      name="vs_targetSchema"
      content="http://schemas.microsoft.com/intellisense/ie5"
    />
    <title>Page not found</title>

    <link
      href="/css/custom.css"
      rel="stylesheet"
      id="pageStyle"
    />
  </head>

  <body>
    <div class="Container">
      <h1 id="lblTitle" runat="server">Resource not found</h1>
      <p>
        The page you were trying to access was not found or no longer exists. If
        you believe that this page should exist, please send an email to
        <a href="mailto:support@q4inc.com"> support@q4inc.com</a
        >&nbsp;explaining the page you were trying to access. Thanks for your
        patience, understanding, and help.
      </p>
      <hr />

      <div style="float: left">
        <a href="/default.aspx">Go back to the home page</a>.
      </div>
      <a href="http://www.q4inc.com" target="_blank"
        ><img
          src="/Images/errorlogo.gif"
          border="0"
          style="float: right"
      /></a>

      <div style="clear: both"></div>
    </div>
  </body>
</html>
